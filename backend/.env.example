# NexTB API 

PORT=8080
HOST=0.0.0.0
NODE_ENV=production

# Comma-separated allowed frontend origins
CORS_ORIGIN=https://your-frontend.example.com,http://localhost:3000

# mo-bi endpoints
CORS_MOBI_BUS_DATA=https://maps.mo-bi.ro/api/busData
CORS_MOBI_NEXT_ARRIVALS=https://maps.mo-bi.ro/api/nextArrivals/
CORS_MOBI_DATASET=https://maps.mo-bi.ro/api/dataset

GTFS_STOPS_FILE=./data/stops.txt
GTFS_SHAPES_FILE=./data/shapes.txt
LINE_CHECK_COOLDOWN=120000
NOACPATH=./data/noAC.json

CRON_SECRET=generate-a-long-random-secret
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DEVICE_HASH_SALT=generate-a-long-random-secret

MIN_MINUTES_PER_STOP=2
AVG_SPEED_METERS_PER_MIN=230
ETA_TOLERANCE_MINUTES=1
STOP_SPACING_METERS=350