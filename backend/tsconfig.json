{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts", "../lib/repo-root.ts", "../lib/server/**/*.ts", "../lib/vehicles/**/*.ts", "../lib/comfort/**/*.ts", "../lib/stops/**/*.ts", "../lib/types.ts", "../lib/i18n.ts"]
}
